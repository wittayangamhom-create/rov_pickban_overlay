{
  "name": "rov-overlay-tool",
  "version": "1.0.0",
  "description": "Arena of Valor Draft Pick Overlay Tool",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "serve": "node server.js",
    "app": "electron .",
    "electron": "electron .",
    "dist": "electron-builder --win --x64",
    "portable": "electron-builder --win portable --x64",
    "dev": "nodemon server.js",
    "check": "node --check server.js && node --check public/js/control.js && node --check public/js/overlay.js && node --check public/js/result.js",
    "check-heroes": "node check-heroes.js"
  },
  "keywords": [
    "rov",
    "arena of valor",
    "overlay",
    "draft pick"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE.md",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "electron-builder": "^26.0.12",
    "electron": "^43.0.0",
    "nodemon": "^2.0.22"
  },
  "build": {
    "appId": "com.rov.overlay.tool",
    "productName": "ROV Overlay Tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "server.js",
      "LICENSE.md",
      "LICENSE.txt",
      "package.json",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE.txt"
    },
    "portable": {
      "artifactName": "ROV-Overlay-Tool-Portable.exe"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
